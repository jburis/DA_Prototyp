<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAF9FB">

    <!-- ================= HEADER ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:background="#FFFFFF"
        android:elevation="6dp">

        <ImageView
            android:layout_width="220dp"
            android:layout_height="60dp"
            android:src="@drawable/kwp_bild"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teilnehmerliste auswählen"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginTop="12dp"/>
    </LinearLayout>


    <!-- ================= LISTVIEW (WICHTIG FÜR JAVA) ================= -->
    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="18dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="14dp"
        android:scrollbars="none"/>


    <!-- ================= ORANGE BUTTON (WICHTIG FÜR JAVA) ================= -->
    <Button
        android:id="@+id/btn_import_pdf"
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:layout_margin="20dp"

        android:text="Zusätzliche Listen laden"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textAllCaps="false"

        android:backgroundTint="#FF6600"
        android:elevation="8dp"/>


    <!-- ================= BOTTOM NAV ================= -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF6600"
        app:itemIconTint="@android:color/white"
        app:itemTextColor="@android:color/white"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>