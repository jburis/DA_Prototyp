<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9FB">

    <!-- ===== MAIN CONTENT ===== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ===== Header ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="6dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:id="@+id/logo"
                    android:layout_width="260dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/kwp_bild"
                    android:contentDescription="Logo"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Check-in"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#1A1A1A"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/textResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kamera manuell starten und dann scannen"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Content padding -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ===== Top Buttons Row ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/scanBtn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Buchungsnr."
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#FF6600"/>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp"/>

                    <Button
                        android:id="@+id/btn_qr"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="QR-Code"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#546E7A"/>
                </LinearLayout>

                <!-- ===== Kamera Toggle ===== -->
                <Button
                    android:id="@+id/btnToggleCamera"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="Kamera AN"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF6600"
                    android:elevation="6dp"/>

                <!-- ===== Kamera Preview Card (ausblendbar) ===== -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cameraCard"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardUseCompatPadding="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <androidx.camera.view.PreviewView
                            android:id="@+id/previewView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                        <TextView
                            android:id="@+id/tvCameraHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="12dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:text="Kamera aktiv – halte QR/Bestellnummer ins Bild"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:background="#99000000"/>
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <!-- ===== Gescannt Card + Liste ===== -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/scannedCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Gescannt"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="#1A1A1A"/>

                            <ImageButton
                                android:id="@+id/btnAddManual"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@android:color/transparent"
                                android:contentDescription="Teilnehmer hinzufügen"
                                android:src="@android:drawable/ic_input_add"
                                android:tint="#FF6600"/>
                        </LinearLayout>

                        <ListView
                            android:id="@+id/scannedList"
                            android:layout_width="match_parent"
                            android:layout_height="260dp"
                            android:layout_marginTop="8dp"
                            android:divider="#EDEDED"
                            android:dividerHeight="1dp"
                            android:background="#FFFFFF"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===== DIM BACKDROP (for popup) ===== -->
    <View
        android:id="@+id/dimView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone" />

    <!-- ===== CONFIRMATION POPUP (Bottom Overlay) ===== -->
    <LinearLayout
        android:id="@+id/confirmationLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="14dp"
        android:visibility="gone"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="28dp"
        android:fitsSystemWindows="true">

        <!-- Drag-Handle -->
        <View
            android:layout_width="44dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:background="#D9D9D9" />

        <!-- Teilnehmer (größer) -->
        <TextView
            android:id="@+id/confirmationTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Teilnehmer: -"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#1A1A1A" />

        <!-- Infos untereinander -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvInfoBestellnr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bestellnr.: -"
                android:textSize="16sp"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tvInfoPlaetze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Plätze: -"
                android:textSize="16sp"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tvInfoEingecheckt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Eingecheckt: -"
                android:textSize="16sp"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tvInfoFrei"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Frei: -"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1A1A1A" />
        </LinearLayout>

        <!-- Plus/Minus Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnMinus"
                android:layout_width="80dp"
                android:layout_height="56dp"
                android:text="-"
                android:textSize="26sp"
                android:textStyle="normal"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935" />

            <TextView
                android:id="@+id/checkInCountText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="1"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#1A1A1A" />

            <Button
                android:id="@+id/btnPlus"
                android:layout_width="80dp"
                android:layout_height="56dp"
                android:text="+"
                android:textSize="26sp"
                android:textStyle="normal"
                android:textColor="#FFFFFF"
                android:backgroundTint="#43A047" />
        </LinearLayout>

        <Button
            android:id="@+id/confirmCheckInBtn"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="14dp"
            android:text="Bestätigen"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF6600" />

        <!-- Extra Abstand, falls Navigation-Bar hoch ist -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="12dp" />

    </LinearLayout>

</FrameLayout>